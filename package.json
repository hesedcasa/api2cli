{
  "name": "@hesed/api2cli",
  "version": "0.3.1",
  "description": "Import OpenAPI, Postman, and GraphQL specs and call their operations as native CLI commands",
  "author": "Hesed",
  "bin": {
    "api": "./bin/run.js"
  },
  "bugs": "https://github.com/hesedcasa/api2cli/issues",
  "dependencies": {
    "@hesed/plugin-lib": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oclif/core": "^4",
    "@scalar/openapi-parser": "^0.28.7",
    "@scalar/postman-to-openapi": "^0.7.8",
    "@scalar/types": "^0.12.2",
    "@toon-format/toon": "^2.3.0",
    "graphql": "^16.13.2",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^5",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10",
    "@types/node": "^25",
    "@types/js-yaml": "^4.0.9",
    "chai": "^6",
    "chai-as-promised": "^8.0.2",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "ts-node": "^10",
    "ts-prune": "^0.10.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/hesedcasa/api2cli",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "api",
    "dirname": "api",
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "hooks": {
      "init": "./dist/hooks/init/register-api-commands"
    },
    "topics": {}
  },
  "repository": "hesedcasa/api2cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md",
    "find-deadcode": "ts-prune --ignore '(run|default)'",
    "format": "eslint --cache --fix --quiet . && prettier --write --cache .",
    "pre-commit": "npm run format && npm run find-deadcode"
  },
  "types": "dist/index.d.ts"
}
